import streamlit as st
import pandas as pd
import plotly.express as px
import plotly.graph_objects as go
import google.generativeai as genai
import json
import re

st.set_page_config(page_title="Creed Chart Assistant", layout="wide")

st.title("📊 Creed AI Chart Assistant")
st.caption("Generate and understand charts from natural language — by Creed")

# Sidebar for API key
with st.sidebar:
    st.header("🔑 Configuration")
    api_key = st.text_input("Google Gemini API Key", type="password", help="Get free key from aistudio.google.com")
    st.markdown("---")
    st.markdown("### How to use:")
    st.markdown("1. Enter your Gemini API key")
    st.markdown("2. Describe what chart you want")
    st.markdown("3. Or upload data (CSV/Excel)")
    
    if api_key:
        genai.configure(api_key=api_key)

# Main area tabs
tab1, tab2 = st.tabs(["✨ Generate Chart from Text", "📁 Upload Data + Create Chart"])

# Tab 1: Text to chart
with tab1:
    st.subheader("Describe the chart you want")
    
    col1, col2 = st.columns([2, 1])
    
    with col1:
        user_prompt = st.text_area("Example: 'Show me sales by month as a bar chart'", height=100)
        chart_type = st.selectbox("Chart type", ["bar", "line", "pie", "scatter"])
        
    with col2:
        st.markdown("### Try these:")
        st.info("📊 'Bar chart: Apples 20, Bananas 35, Oranges 15'")
        st.info("📈 'Line chart: Jan 100, Feb 150, Mar 200'")
        st.info("🥧 'Pie chart: Red 30%, Blue 45%, Green 25%'")
    
    if st.button("✨ Generate Chart", type="primary"):
        if not api_key:
            st.error("Please enter your Gemini API key in the sidebar")
        elif not user_prompt:
            st.warning("Please describe the chart you want")
        else:
            with st.spinner("Creed AI is creating your chart..."):
                try:
                    model = genai.GenerativeModel('gemini-1.5-flash')
                    response = model.generate_content(f"""
                    Extract data from this request and return ONLY valid JSON.
                    Request: "{user_prompt}"
                    
                    Return format: {{"type": "bar", "labels": ["A","B"], "values": [10,20], "title": "Chart Title"}}
                    """)
                    
                    text = response.text.strip()
                    text = re.sub(r'```json\n?|```\n?', '', text)
                    data = json.loads(text)
                    
                    df = pd.DataFrame({'label': data['labels'], 'value': data['values']})
                    
                    if data['type'] == 'bar':
                        fig = px.bar(df, x='label', y='value', title=data.get('title', user_prompt))
                    elif data['type'] == 'line':
                        fig = px.line(df, x='label', y='value', title=data.get('title', user_prompt))
                    elif data['type'] == 'pie':
                        fig = px.pie(df, names='label', values='value', title=data.get('title', user_prompt))
                    else:
                        fig = px.scatter(df, x='label', y='value', title=data.get('title', user_prompt))
                    
                    st.plotly_chart(fig, use_container_width=True)
                    st.success("✅ Chart generated by Creed AI!")
                    
                except Exception as e:
                    st.error(f"Try a simpler format. Error: {e}")

# Tab 2: Upload data
with tab2:
    st.subheader("Upload your data file")
    uploaded_file = st.file_uploader("Choose CSV or Excel file", type=['csv', 'xlsx'])
    
    if uploaded_file:
        try:
            if uploaded_file.name.endswith('.csv'):
                df = pd.read_csv(uploaded_file)
            else:
                df = pd.read_excel(uploaded_file)
            
            st.write("### Data Preview")
            st.dataframe(df.head())
            
            x_col = st.selectbox("X-axis", df.columns)
            y_col = st.selectbox("Y-axis", df.columns)
            chart_type_data = st.selectbox("Chart type", ["bar", "line", "scatter"])
            
            if st.button("Generate from Data"):
                if chart_type_data == 'bar':
                    fig = px.bar(df, x=x_col, y=y_col)
                elif chart_type_data == 'line':
                    fig = px.line(df, x=x_col, y=y_col)
                else:
                    fig = px.scatter(df, x=x_col, y=y_col)
                st.plotly_chart(fig, use_container_width=True)
                
        except Exception as e:
            st.error(f"Error: {e}")

st.markdown("---")
st.markdown("Built with ❤️ by **Creed**")
